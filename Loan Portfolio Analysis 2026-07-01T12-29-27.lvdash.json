{
  "datasets": [
    {
      "name": "mom_collateral_change",
      "displayName": "Month-over-Month Collateral Change",
      "queryLines": [
        "with monthly_collateral as (\n",
        "  select\n",
        "    loan_id,\n",
        "    snapshot_date,\n",
        "    round(sum(market_value), 2) as total_collateral_value\n",
        "  from\n",
        "    collateral_holdings\n",
        "  group by\n",
        "    loan_id,\n",
        "    snapshot_date\n",
        ")\n",
        "select\n",
        "  loan_id,\n",
        "  snapshot_date,\n",
        "  total_collateral_value,\n",
        "  lag(total_collateral_value) over (\n",
        "      partition by loan_id\n",
        "      order by snapshot_date\n",
        "    ) as prev_month_value,\n",
        "  round(\n",
        "    total_collateral_value\n",
        "      - lag(total_collateral_value) over (partition by loan_id order by snapshot_date),\n",
        "    2\n",
        "  ) as mom_change,\n",
        "  round(\n",
        "    100.0\n",
        "      * (\n",
        "        total_collateral_value\n",
        "          - lag(total_collateral_value) over (partition by loan_id order by snapshot_date)\n",
        "      )\n",
        "      / lag(total_collateral_value) over (partition by loan_id order by snapshot_date),\n",
        "    2\n",
        "  ) as mom_pct_change\n",
        "from\n",
        "  monthly_collateral\n",
        "order by\n",
        "  loan_id,\n",
        "  snapshot_date"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "ltv_breach_analysis",
      "displayName": "LTV Breach Analysis",
      "queryLines": [
        "with tier_rules as (\n",
        "  select\n",
        "    *\n",
        "  from\n",
        "    values\n",
        "      ('Tier 1 - Prime', 0.70, 0.75),\n",
        "      ('Tier 2 - Standard', 0.65, 0.70),\n",
        "      ('Tier 3 - Subprime', 0.60, 0.65),\n",
        "      ('Tier 4 - High Risk', 0.50, 0.55) as t(credit_tier, max_ltv, maintenance_ltv)\n",
        ")\n",
        "select\n",
        "  l.loan_id,\n",
        "  l.client_id,\n",
        "  l.credit_tier,\n",
        "  l.loan_amount,\n",
        "  round(sum(ch.market_value), 2) as collateral_value,\n",
        "  round(l.loan_amount / sum(ch.market_value), 4) as ltv_ratio,\n",
        "  r.max_ltv,\n",
        "  r.maintenance_ltv\n",
        "from\n",
        "  loans l\n",
        "    join collateral_holdings ch\n",
        "      on l.loan_id = ch.loan_id\n",
        "    join tier_rules r\n",
        "      on l.credit_tier = r.credit_tier\n",
        "where\n",
        "  ch.snapshot_date = '2025-06-01'\n",
        "group by\n",
        "  l.loan_id,\n",
        "  l.client_id,\n",
        "  l.credit_tier,\n",
        "  l.loan_amount,\n",
        "  r.max_ltv,\n",
        "  r.maintenance_ltv"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "avg_loan_by_segment",
      "displayName": "Average Loan by Segment",
      "queryLines": [
        "select\n",
        "  c.segment,\n",
        "  round(avg(l.loan_amount), 2) as avg_loan_amount\n",
        "from\n",
        "  loans l\n",
        "    join clients c\n",
        "      on l.client_id = c.client_id\n",
        "group by\n",
        "  c.segment\n",
        "order by\n",
        "  avg_loan_amount desc"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "top_10_high_ltv",
      "displayName": "Top 10 High LTV Loans",
      "queryLines": [
        "select\n",
        "  l.loan_id,\n",
        "  l.client_id,\n",
        "  l.credit_tier,\n",
        "  l.loan_amount,\n",
        "  round(sum(ch.market_value), 2) as total_collateral_value,\n",
        "  round(l.loan_amount / sum(ch.market_value), 4) as ltv_ratio\n",
        "from\n",
        "  loans l\n",
        "    join collateral_holdings ch\n",
        "      on l.loan_id = ch.loan_id\n",
        "group by\n",
        "  l.loan_id,\n",
        "  l.client_id,\n",
        "  l.credit_tier,\n",
        "  l.loan_amount\n",
        "order by\n",
        "  ltv_ratio desc\n",
        "limit 10"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "regional_breach_analysis",
      "displayName": "Regional Breach Analysis",
      "queryLines": [
        "with tier_rules as (\n",
        "  select\n",
        "    *\n",
        "  from\n",
        "    values\n",
        "      ('Tier 1 - Prime', 0.70, 0.75),\n",
        "      ('Tier 2 - Standard', 0.65, 0.70),\n",
        "      ('Tier 3 - Subprime', 0.60, 0.65),\n",
        "      ('Tier 4 - High Risk', 0.50, 0.55) as t(credit_tier, max_ltv, maintenance_ltv)\n",
        "),\n",
        "loan_ltv as (\n",
        "  select\n",
        "    l.loan_id,\n",
        "    c.region,\n",
        "    l.credit_tier,\n",
        "    round(l.loan_amount / sum(ch.market_value), 4) as ltv_ratio\n",
        "  from\n",
        "    loans l\n",
        "      join clients c\n",
        "        on l.client_id = c.client_id\n",
        "      join collateral_holdings ch\n",
        "        on l.loan_id = ch.loan_id\n",
        "  where\n",
        "    ch.snapshot_date = '2025-06-01'\n",
        "  group by\n",
        "    l.loan_id,\n",
        "    c.region,\n",
        "    l.credit_tier,\n",
        "    l.loan_amount\n",
        "),\n",
        "flagged as (\n",
        "  select\n",
        "    ll.region,\n",
        "    case\n",
        "      when ll.ltv_ratio > r.max_ltv then 1\n",
        "      else 0\n",
        "    end as is_breach\n",
        "  from\n",
        "    loan_ltv ll\n",
        "      join tier_rules r\n",
        "        on ll.credit_tier = r.credit_tier\n",
        ")\n",
        "select\n",
        "  region,\n",
        "  round(100.0 * sum(is_breach) / count(*), 2) as pct_loans_breaching,\n",
        "  count(*) as total_loans\n",
        "from\n",
        "  flagged\n",
        "group by\n",
        "  region\n",
        "order by\n",
        "  pct_loans_breaching desc"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "collateral_by_asset_type",
      "displayName": "Collateral by Asset Type",
      "queryLines": [
        "select\n",
        "  asset_type,\n",
        "  round(sum(market_value), 2) as total_collateral_value\n",
        "from\n",
        "  collateral_holdings\n",
        "group by\n",
        "  asset_type\n",
        "order by\n",
        "  total_collateral_value desc"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "credit_tier_distribution",
      "displayName": "Credit Tier Distribution",
      "queryLines": [
        "select\n",
        "  credit_tier,\n",
        "  count(*) as client_count\n",
        "from\n",
        "  clients\n",
        "group by\n",
        "  credit_tier\n",
        "order by\n",
        "  client_count desc"
      ],
      "catalog": "workspace",
      "schema": "default"
    }
  ],
